{
  "buildCommand": "composer install --no-dev --optimize-autoloader",
  "outputDirectory": "public",
  "installCommand": "composer install --no-dev --optimize-autoloader",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/public/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "CI_ENVIRONMENT": "production"
  }
}
